{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "Freeze Frame",
  "description": "Adds Cameras to Minecraft in an intuitive and vanilla way.",
  "authors": [
    "Lunade/AViewFromTheTop",
    "Lufurrius"
  ],
  "contributors": [
    "zntm"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/freeze-frame",
    "sources": "https://github.com/FrozenBlock/FreezeFrame",
    "issues": "https://github.com/FrozenBlock/FreezeFrame/issues"
  },
  "license": "FrozenBlock Modding Oasis License v1.0",
  "icon": "assets/freezeframe/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.frozenblock.freezeframe.FreezeFrame"
    ],
    "client": [
      "net.frozenblock.freezeframe.FreezeFrameClient"
    ],
    "modmenu": [
      "net.frozenblock.freezeframe.config.gui.ModMenuIntegration"
    ],
    "fabric-datagen": [
      "net.frozenblock.freezeframe.datagen.FFDataGenerator"
    ]
  },
  "mixins": [
    "freezeframe.mixins.json"
  ],
  "accessWidener": "freezeframe.classtweaker",
  "depends": {
    "frozenlib": "${frozenlib_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "java": ">=25"
  },
  "suggests": {
    "cloth-config": "*",
    "modmenu": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "X": "https://x.com/FB_Oasis",
        "Bluesky": "https://bsky.app/profile/frozenblock.bsky.social",
        "modmenu.discord": "https://discord.gg/frozenblock-modding-oasis-780746010614956112",
        "modmenu.modrinth": "https://modrinth.com/organization/frozenblock",
        "modmenu.youtube": "https://www.youtube.com/@frozenblockmoddingoasismod",
        "modmenu.kofi": "https://ko-fi.com/frozenblock"
      },
      "badges": [
        "frozenblock"
      ]
    },
    "frozenlib_registry": {
      "mod_protocol": $protocol_version
    }
  }
}
